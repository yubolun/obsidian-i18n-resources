                    "target": "setTitle(`Renaming #${s} (and any sub-tags)`)"
                },
                {
                    "source": "Notice(`\"${t}\" is not a valid Obsidian tag name`)",
                    "target": "Notice(`\"${t}\" is not a valid Obsidian tag name`)"
                },
